{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"root": true,
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"includes": [
			"**/src/**/*",
			"**/*.config.ts",
			"!src-tauri",
			"!submodules",
			"!node_modules",
			"!dist",
			"!build",
			"!generated",
			"!.expo",
			"!.nitro",
			"!src/components/ui",
			"!**/routeTree.gen.ts",
			"!**/*.d.ts"
		],
		"ignoreUnknown": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"useExhaustiveDependencies": "off",
				"noUnusedImports": {
					"level": "warn"
				},
				"noChildrenProp": "off",
				"noUnusedVariables": {
					"level": "warn",
					"options": {
						"ignoreRestSiblings": true
					}
				}
			},
			"style": {
				"useNumberNamespace": "off"
			},
			"nursery": {
				"useSortedClasses": {
					"level": "warn",
					"fix": "safe",
					"options": {
						"attributes": ["class", "className"]
					}
				},
				"noFloatingPromises": "info"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"semicolons": "always",
			"arrowParentheses": "always"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"indentWidth": 2
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": true
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
